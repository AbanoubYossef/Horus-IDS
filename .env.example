# ── HORUS SOC — Environment Configuration ────────────────────────────────────
# cp .env.example .env

# ── HORUS API ─────────────────────────────────────────────────────────────────
HORUS_HOST=0.0.0.0
HORUS_PORT=8000

# Leave empty to disable auth
HORUS_API_KEY=
HORUS_CORS_ORIGINS=*

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=
VITE_API_KEY=

# ── Capture service ───────────────────────────────────────────────────────────
HORUS_API_URL=http://127.0.0.1:8000
CAPTURE_IFACE=eth1
MGMT_IFACE=eth0

# ── Syslog output ─────────────────────────────────────────────────────────────
SYSLOG_SERVER=10.40.0.x
SYSLOG_PORT=514
ALERT_MIN_SEVERITY=medium

# ── Batching ──────────────────────────────────────────────────────────────────
BATCH_SIZE=100
BATCH_TIMEOUT_S=2.0

# ── Inbound listener ports ────────────────────────────────────────────────────
NETFLOW_PORT=2055
SYSLOG_LISTEN_PORT=514
SNMP_PORT=162

# ── Active response via SSH ───────────────────────────────────────────────────
SSH_KEY_PATH=~/.ssh/utcnbogyou_lab
SSH_KNOWN_HOSTS=~/.ssh/horus_known_hosts
SSH_USER=UTCNBOGYOU
SSH_ENABLE_PASSWORD=
RESPONSE_MIN_SEVERITY=high
RESPONSE_BLOCK_TTL=300
# format: vlan:ip;ip,vlan:ip
SWITCH_VLAN_MAP=51:10.99.0.51;10.99.0.52,52:10.99.0.51;10.99.0.52,20:10.99.0.20,21:10.99.0.21,30:10.99.0.30

# ── Known server IPs ─────────────────────────────────────────────────────────
IDS_HOST_IP=10.40.0.10
APP_SERVER_IP=10.20.0.10
FILE_SERVER_IP=10.21.0.10
DATABASE_IP=10.30.0.10

# ── Detection thresholds ──────────────────────────────────────────────────────
DDOS_RATE_THRESHOLD_MBPS=100
PORTSCAN_UNIQUE_PORTS_THRESHOLD=50
BRUTEFORCE_ATTEMPTS_THRESHOLD=10
BOT_BEACON_INTERVAL_SECONDS=30

# ── Firewall integration ─────────────────────────────────────────────────────
PALOALTO_MGMT_IP=TBD
PALOALTO_API_KEY=TBD
PALOALTO_BLOCK_TAG=IDS-AUTO-BLOCK
PALOALTO_CA_CERT=
FMC_IP=TBD
FMC_USER=TBD
FMC_PASS=TBD
FMC_DOMAIN_UUID=TBD
EDGE_R1_IP=TBD
EDGE_R2_IP=TBD

# ── Security management zone (10.40.40.0/24) — not yet active ────────────────
SIEM_IP=10.40.40.10
NTP_IP=10.40.40.40
TACACS_IP=10.40.40.60
FREERADIUS_IP=10.40.40.61
ANSIBLE_IP=10.40.40.70
JUMP_SERVER_IP=10.40.40.80

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
